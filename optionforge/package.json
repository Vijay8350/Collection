{
  "name": "optionforge",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "typecheck": "tsc --noEmit",
    "worker": "tsx workers/index.ts"
  },
  "type": "module",
  "engines": {
    "node": "^20.10 || ^22.0 || ^24.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@prisma/client": "^6.0.0",
    "@remix-run/dev": "^2.16.0",
    "@remix-run/node": "^2.16.0",
    "@remix-run/react": "^2.16.0",
    "@remix-run/serve": "^2.16.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.7.0",
    "@shopify/shopify-app-session-storage-prisma": "^6.0.0",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.1",
    "isbot": "^5.1.0",
    "mathjs": "^14.0.0",
    "openai": "^4.78.0",
    "prisma": "^6.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite-tsconfig-paths": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.1.0",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "author": "DeoDap Marketplace"
