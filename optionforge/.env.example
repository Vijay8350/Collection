# Shopify app credentials (from Partner Dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products,read_product_listings,read_orders,read_themes,write_themes,read_files,write_files,read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,write_cart_transforms,read_translations,write_translations,read_locales,read_markets
SHOPIFY_APP_URL=https://example.com

# Database — PostgreSQL (required)
# Local dev:  docker run --name optionforge-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/optionforge?schema=public"

# Redis (BullMQ queue + cache)
REDIS_URL="redis://localhost:6379"

# DeepSeek (AI Studio) — OpenAI-compatible API
# Get key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Pin the explicit versioned model — the bare `deepseek-chat` alias retires 2026-07-24.
DEEPSEEK_MODEL=deepseek-v3.2
# LLM provider selector (currently: deepseek). Behind the LLMProvider interface.
LLM_PROVIDER=deepseek

# Cloudflare R2 (file uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=optionforge-uploads
R2_PUBLIC_URL=https://files.optionforge.app

# Encryption (for access_token at rest) — generate with: openssl rand -hex 32
SHOP_TOKEN_ENCRYPTION_KEY=

# Observability (optional)
AXIOM_TOKEN=
SENTRY_DSN=

# Plan limits (override defaults)
AI_GEN_PER_MONTH_FREE=5
AI_GEN_PER_MONTH_PRO=50
AI_GEN_PER_MONTH_PREMIUM=500

# Migration pricing (Blueprint §2.7): free on paid plans; Free-tier free for
# the first N days post-install, then a one-time fee.
MIGRATION_FREE_DAYS=90
MIGRATION_FEE_USD=49

# Billing (Shopify Billing API). Test mode never charges real cards — keep it
# true while testing on a dev store; set false to charge merchants for real.
# Unset → defaults to true unless NODE_ENV=production.
BILLING_TEST=true

NODE_ENV=development
